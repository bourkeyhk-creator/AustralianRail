# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=australian_rail
DB_USER=postgres
DB_PASSWORD=your_password

# API Keys
GOOGLE_NEWS_API_KEY=your_google_news_api_key
PERPLEXITY_API_KEY=your_perplexity_api_key
